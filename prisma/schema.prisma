generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  STUDENT
  ADMIN
}

enum QuestionType {
  MCQ
  SHORT_ANSWER
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  GRADED
}

model User {
  id          String        @id @default(cuid())
  email       String        @unique
  password    String
  name        String
  role        Role          @default(STUDENT)
  createdAt   DateTime      @default(now())
  enrollments Enrollment[]
  attempts    TestAttempt[]
}

model Course {
  id          String          @id @default(cuid())
  title       String
  description String?
  createdAt   DateTime        @default(now())
  enrollments Enrollment[]
  materials   StudyMaterial[]
  tests       Test[]
}

model Enrollment {
  id         String   @id @default(cuid())
  userId     String
  courseId   String
  enrolledAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

enum MaterialFileType {
  PDF
  IMAGE
}

model StudyMaterial {
  id          String           @id @default(cuid())
  courseId    String
  title       String
  description String?
  fileName    String
  fileType    MaterialFileType
  mimeType    String
  fileData    Bytes
  createdAt   DateTime         @default(now())
  course      Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

enum TestFormat {
  ONLINE
  WRITTEN
}

model Test {
  id              String        @id @default(cuid())
  courseId        String
  title           String
  description     String?
  format          TestFormat    @default(ONLINE)
  durationMinutes Int?
  createdAt       DateTime      @default(now())
  course          Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  questions       Question[]
  attempts        TestAttempt[]
}

model Question {
  id            String       @id @default(cuid())
  testId        String
  type          QuestionType
  question      String
  options       String?
  correctAnswer String?
  maxMarks      Int          @default(1)
  test          Test         @relation(fields: [testId], references: [id], onDelete: Cascade)
  answers       Answer[]
}

model TestAttempt {
  id            String        @id @default(cuid())
  testId        String
  userId        String
  status        AttemptStatus @default(IN_PROGRESS)
  startedAt     DateTime?
  submittedAt   DateTime?
  gradedAt      DateTime?
  totalMarks    Int?
  obtainedMarks Int?
  test          Test          @relation(fields: [testId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers       Answer[]
}

model Answer {
  id                 String      @id @default(cuid())
  attemptId          String
  questionId         String
  response           String
  attachmentData     Bytes?
  attachmentMimeType String?
  attachmentFileName String?
  isCorrect          Boolean?
  marksAwarded       Int?
  feedback           String?
  attempt            TestAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question           Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
}
