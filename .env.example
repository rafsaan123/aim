# Production on Vercel — Turso (https://turso.tech)
# Required on Vercel:
TURSO_DATABASE_URL="libsql://your-db-name.turso.io"
TURSO_AUTH_TOKEN="your-auth-token"

# Local development only (do NOT set on Vercel)
# DATABASE_URL="file:./dev.db"

# Required in production — use a long random string
JWT_SECRET="change-this-to-a-secure-random-string"

# Email notifications (Hostinger SMTP)
# If smtp.hostinger.com fails, use Hostinger Titan: SMTP_HOST=smtp.titan.email
SMTP_HOST="smtp.hostinger.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="mehedirubel@aimsurveyjob.com"
SMTP_PASS="your-mailbox-password"
EMAIL_FROM="AIM Coaching <mehedirubel@aimsurveyjob.com>"
APP_URL="https://aimsurveyjob.com"
